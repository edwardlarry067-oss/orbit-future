{
  "version": 2,
  "installCommand": "npm install && npm install -g pnpm 2>/dev/null; cd artifacts && pnpm install --frozen-lockfile",
  "buildCommand": "cd artifacts && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/spacex-starlink run build",
  "outputDirectory": "artifacts/spacex-starlink/dist",
  "functions": {
    "api/index.mjs": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "env": {
    "VITE_API_URL": "",
    "NODE_VERSION": "20"
  }
}
